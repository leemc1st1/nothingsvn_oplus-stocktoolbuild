[EngineercameraConfigITS]
#For ITS-test set AE-Exposuretime, match SensorName to ITS_Id[0~3],and pay attention:
# 1)only need to write cameras in multicam-system. 2)If project uses two or more modules on one position, just write them on the list and match the same ITS_Id.)
    #Example1: Main(rear)->0, Wide(rearsub1)->1, Tele(rearsub2)->2
    #Example2: Main(rear)->0, Wide(rearsub1)->1
    #Example3: Main(rear)->0, Tele(rearsub1)->1
    #Example4: Main(rear)->0, White(rearsub1)->1
                            #SensorName                      #ITS_Id
    SensorITS[0]=            macanWide;                    		1;
    SensorITS[1]=            macanMain;                         0;

