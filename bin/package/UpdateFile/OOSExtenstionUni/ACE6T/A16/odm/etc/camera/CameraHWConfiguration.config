        macanMain[0x0040][0x800C]              = 14;      #Time-lapse DCG
        macanMain[0x0002][0x800C]              = 30;      #Time-lapse binning
        macanMain[0x0002][0x80B3]              = 30;      #video virtualization main
        macanMain[0x0002][0x8009]              = 1;       #binning
        macanMain[0x0002][0x8007]              = 11;      #Panorama
        macanMain[0x0002][0x8011]              = 8;       #portrait 1x/2x 1exp
        macanMain[0x0008][0x8011]              = 39;      #portrait 2x mmf izoom
        macanMain[0x0002][0x802C]              = 11;      #VideoMultiScene 30fps
        macanMain[0x0040][0x802C]              = 11;      #VideoMultiScene 30fps

        macanWide[0x0002][-1]                  = 0;       #binning
        macanWide[0x0200][-1]                  = 0;       #video 60fps standby
        macanWide[0x0002][0x8011]              = 1;       #portrait 1x 1exp
        macanWide[0x0002][0x800B]              = 4;       #VIDEO 30FPS BINNING
        macanWide[0x0002][0x8028]              = 4;       #superEIS 30fps binning
        macanWide[0x0002][0x800C]              = 4;       #Time-lapse 30FPS BINNING
        macanWide[0x0002][0x80A3]              = 4;       #MOVIE 30FPS
        macanWide[0x0002][0x80A4]              = 4;       #MOVIE 30FPS EIS
        macanWide[0x0002][0x8007]              = 3;       #Panorama

        macanFront[0x0002][-1]                 = 1;       #binning
        macanFront[0x0020][-1]                 = 0;       #QCFA
