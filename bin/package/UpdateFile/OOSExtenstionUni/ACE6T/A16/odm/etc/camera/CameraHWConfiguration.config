##############caps_mask##############
# ┌───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────┐
# │ Bit7          │ Bit6          │ Bit5          │ Bit4          │ Bit3          │ Bit2          │ Bit1          │ Bit0          │
# ┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼
# │DCGSensorMerged│ DCGDirectMode │ FullSizeRaw   │ QBC           │ Izoom         │ LBMF          │ 1Exp          │ SeamlessSwitch│
# └───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴
# ┌───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────┬───────────────┐
# │ Bit15         │ Bit14         │ Bit13         │ Bit12         │ Bit11         │ Bit10         │ Bit9          │ Bit8          │
# ┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼───────────────┼
# │FullSizeRawQBC2│ EnableDCGVS   │ Dolby         │ 480fps        │ 240fps        │ 120fps        │ 60fps         │ 24fps         │
# └───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴───────────────┴
# ┌───────────────┬───────────────┬───────────────┬───────────────┐
# │ Bit19         │ Bit18         │ Bit17         │ Bit16         │
# ┼───────────────┼───────────────┼───────────────┼───────────────┼
# │Reserved       │ Reserved      │ Reserved      │ VideoHSR      │
# └───────────────┴───────────────┴───────────────┴───────────────┴
# High frequency combination:
#  caps_mask       sesnor_aps
#   0x0002          1exp binning
#   0x0200          1exp binning 60fps
#   0x0400          1exp binning 120fps
#   0x0004          lbmf
#   0x0008          izoom hwRemosaic
#   0x000C          lbmf izoom
#   0x0018          izoom qbc
#   0x001C          lbmf izoom qbc
#   0x0020          full size hwRemosaic
#   0x0030          full size qbc
#   0x0040          dcg 2exp
#   0x0048          dcg 2exp izoom
#   0x0280          dcg 1exp 12bit 60fps
#   0x2040          dolby dcg 2exp
#   0x2048          dolby dcg 2exp izoom
#   0x2280          dolby dcg 1exp 12bit 60fps
#   0x2000          dolby 1exp binning
#   0x2008          dolby izoom
#   0x2200          dolby 1exp binning 60fps
#   0x2400          dolby 1exp binning 120fps
#   0x0400          120fps slo-motion
#   0x0800          240fps slo-motion
#   0x1000          480fps slo-motion
#   0x10000         VideoHSR
#
# If the sensor capabilities are the same but the size is different, we need to use opmode to distinguish them.
#####################################

[OemCamSeamlessSettingMap]
    # sensorName[caps_mask][opMode]      =  mode index
        macanMain[0x0040][-1]                  = 11;      #DAG
